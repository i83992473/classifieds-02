# ======================================================================
# Classified-02 Ad Editor — environment variable contract
# ----------------------------------------------------------------------
# This file is committed. `.env.local` (your real values) is gitignored.
# Copy this file to `.env.local` and fill in the blanks before running
# `npm run dev`, `npm test`, or any deploy script.
#
# Rule: any process.env.X or import.meta.env.VITE_X read added to the
# codebase MUST also be listed here, in the same commit. See PRD §9.5.
#
# Naming convention:
#   VITE_*   → inlined into the browser bundle at build time (public)
#   (no prefix) → shell / Node / test-runner / deploy only
# ======================================================================


# ─── Layer-3 E2E testing (Firecrawl) ─────────────────────────────────
# Firecrawl API key for the agent-driven E2E flows described in PRD §11.5.
# Obtain a key at https://www.firecrawl.dev/app
# Secret — never commit a real value.
FIRECRAWL_API_KEY=


# ─── Dev / test (Vite, Vitest) ───────────────────────────────────────
# Optional dev-only override for the assets CDN origin. Production reads
# this from /public/config.json at page load, NOT from env — so leave
# blank unless you're pointing a dev build at a non-default bucket.
# Example: https://editor-assets.mirabeltech.com
VITE_ASSETS_ORIGIN=

# URL of the local stub server that serves /sign-upload and acts as the
# callbackUrl target during Phase 3 integration tests. Default matches
# the stub launched by `npm run dev:stub` (to be added in Phase 3).
VITE_DEV_MAIN_APP_ORIGIN=http://localhost:8787


# ─── AWS deploy (consumed by infra/setup.sh and deploy scripts) ──────
# CloudFront distribution IDs for cache invalidation after a deploy.
# Populated once Phase 4 provisioning creates the distributions;
# until then leave blank — deploy script should fail loudly if missing.
EDITOR_DIST_ID=
ASSETS_DIST_ID=

# AWS CLI profile used by every `aws` invocation in this project.
# Fixed value — do not change. Must match the profile name in
# ~/.aws/credentials (account 539247468693).
AWS_PROFILE=classifieds-admin
